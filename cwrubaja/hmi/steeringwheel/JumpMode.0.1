#Defines an enum for the semi-active suspension modes we may see
uint8 value

uint8 FLAT = 0
#default mode, for driving on flat ground

uint8 JUMP = 1
#mode for jumps

uint8 FLAT_TURN = 2
#Turning on flat ground

uint8 BANK_TURN = 3
#Turn on a banked turn

uint8 BANK_STRAIGHT = 4
#Driving straight down a banked section

uint8 BIPS = 5
#High frequency small bumps

uint8 BONKS = 6
#low frequency large bumps

uint8 WHOOPS = 7
